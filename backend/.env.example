# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=true
BACKEND_RELOAD=true

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=djsetlist_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password_here@postgres:5432/djsetlist_db
DATABASE_URL_SYNC=postgresql://postgres:your_secure_password_here@postgres:5432/djsetlist_db

# Qwen AI / OpenAI-compatible API
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=http://your-server-ip:42005/v1
LLM_API_MODEL=coder-model

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://your-server-ip:3000"]

# pgAdmin (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
